<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="CENTER" style="-fx-padding: 40; -fx-background-color: #f0f4f8;"
      xmlns:fx="http://javafx.com/fxml" fx:controller="com.student.studentapp.LoginController">

    <Label text="Student App" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <Label text="Please log in to continue" style="-fx-text-fill: gray;"/>

    <TextField fx:id="txtUsername" promptText="Username" prefWidth="250"/>
    <PasswordField fx:id="txtPassword" promptText="Password" prefWidth="250"/>

    <Label fx:id="lblError" style="-fx-text-fill: red;"/>

    <Button text="Login" onAction="#handleLogin" prefWidth="250"
            style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 14px;"/>
</VBox>